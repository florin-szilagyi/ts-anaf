{
  "name": "@florinszilagyi/anaf-mcp",
  "version": "0.1.0",
  "description": "MCP server for the ANAF e-Factura SDK — exposes lookup, UBL, upload, status, download, messages, validate as tools",
  "license": "MIT",
  "author": {
    "name": "Florin Szilagyi",
    "url": "https://github.com/florin-szilagyi"
  },
  "type": "module",
  "bin": {
    "anaf-mcp": "dist/server.js"
  },
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": ["dist/**/*", "README.md", "LICENSE"],
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "dev": "tsx src/server.ts",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts' --no-error-on-unmatched-pattern",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix --no-error-on-unmatched-pattern",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests",
    "verify": "pnpm run lint && pnpm run build && pnpm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@florinszilagyi/anaf-ts-sdk": "workspace:*",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3"
  }
}
