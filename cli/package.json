{
  "name": "@florinszilagyi/anaf-cli",
  "version": "1.0.0",
  "description": "CLI for the ANAF e-Factura SDK (anaf-ts-sdk)",
  "license": "MIT",
  "author": {
    "name": "Florin Szilagyi",
    "url": "https://github.com/florin-szilagyi"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/florin-szilagyi/ts-anaf.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/florin-szilagyi/ts-anaf/issues"
  },
  "keywords": ["anaf", "efactura", "cli", "romania", "ubl", "invoice"],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "anaf-cli": "dist/bin/anaf-cli.cjs"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": ["dist/**/*", "README.md", "LICENSE"],
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "pnpm run clean && pnpm run build:tsc && pnpm run build:bundle",
    "build:tsc": "tsc -p tsconfig.build.json",
    "build:bundle": "node scripts/build-bundle.mjs",
    "build:sea": "node scripts/build-sea.mjs",
    "dev": "tsx src/bin/anaf-cli.ts",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=smoke",
    "test:smoke": "jest --testPathPattern=smoke --runInBand",
    "verify": "pnpm run lint && pnpm run build && pnpm run test",
    "gen-docs": "tsx scripts/gen-docs.ts",
    "gen-docs:check": "tsx scripts/gen-docs.ts --out COMMANDS.md.tmp && diff COMMANDS.md COMMANDS.md.tmp && rm COMMANDS.md.tmp || (rm -f COMMANDS.md.tmp && echo 'COMMANDS.md is stale — run: pnpm gen-docs' && exit 1)"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@florinszilagyi/anaf-ts-sdk": "workspace:*",
    "esbuild": "^0.21.5",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3"
  }
}
